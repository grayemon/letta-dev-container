# .env.example - Copy this to .env and fill in your values
# For an external Letta API configuration

# Your unique Letta API Key (get from your Letta Dashboard)
LETTA_API_KEY=your_letta_api_key_here

# The base URL for your external Letta server (e.g. cloud or local instance)
LETTA_BASE_URL=https://api.letta.ai

# Default development port
PORT=8999
